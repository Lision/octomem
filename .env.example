# ============================================
# LLM Configuration (OpenAI-compatible)
# ============================================

# Default: OpenAI
# OPENAI_API_KEY=sk-xxx

# Custom OpenAI-compatible LLM (e.g., ZhipuAI, DeepSeek, Moonshot, etc.)
# Set OPENAI_API_KEY to your provider's API key, then configure:
# LLM_BASE_URL=https://your-provider-api.com/v1
# LLM_MODEL=your-model-id
