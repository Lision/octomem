# ============================================
# LLM Configuration (OpenAI-compatible)
# ============================================

# Default: OpenAI
# OPENAI_API_KEY=sk-xxx

# Custom OpenAI-compatible LLM (e.g., ZhipuAI, DeepSeek, Moonshot, etc.)
# Set OPENAI_API_KEY to your provider's API key, then configure:
# LLM_BASE_URL=https://your-provider-api.com/v1
# LLM_MODEL=your-model-id

# ============================================
# Embedding Configuration (independent from LLM)
# ============================================

# Not all OpenAI-compatible providers support /v1/embeddings (e.g., Zhipu).
# You can use a different provider for embedding than for LLM.
#
# Option A: Ollama (local, free, recommended)
#   1. Install Ollama: https://ollama.com
#   2. Pull model: ollama pull bge-m3
#   3. Uncomment the lines below:
# EMBEDDING_BASE_URL=http://localhost:11434/v1
# EMBEDDING_MODEL=bge-m3
#
# Option B: SiliconFlow (cloud, free tier available)
#   Get API key at https://cloud.siliconflow.cn
#   Uncomment and fill the lines below:
# EMBEDDING_API_KEY=sk-your-siliconflow-key
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_MODEL=BAAI/bge-m3
#
# Option C: OpenAI
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
