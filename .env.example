# ============================================
# LLM Configuration (OpenAI-compatible)
# ============================================

# Default: OpenAI
# OPENAI_API_KEY=sk-xxx

# Custom OpenAI-compatible LLM (e.g., ZhipuAI, DeepSeek, Moonshot, etc.)
# Set OPENAI_API_KEY to your provider's API key, then configure:
# LLM_BASE_URL=https://your-provider-api.com/v1
# LLM_MODEL=your-model-id

# ============================================
# Embedding Configuration (independent from LLM)
# ============================================

# Not all OpenAI-compatible providers support /v1/embeddings (e.g., Zhipu).
# You can use a different provider for embedding than for LLM.
# EMBEDDING_API_KEY=sk-xxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
